upstream vaultwarden-default {
  zone vaultwarden-default 64k;
  server vaultwarden:80;
  keepalive 2;
}

geo $is_local {
    default		0;
    <your_net/cidr>	1;
}

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      "";
}

server {
    listen 80;

    server_name <full_server_name>;
    server_tokens off;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    if ($is_local) {
	return 301 https://$host$request_uri;
    }

    location / {
	proxy_pass http://vaultwarden-default;
    }
}


server {
    listen 443 ssl; # managed by Certbot
    http2 on;
    server_name <full_server_name>;

    ssl_certificate /etc/nginx/ssl/live/<full_server_name>/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/nginx/ssl/live/<full_server_name>/privkey.pem; # managed by Certbot
    add_header Strict-Transport-Security "max-age=31536000;";

    client_max_body_size 525M;

    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;

    location / {
      proxy_pass http://vaultwarden-default;
    }
}
